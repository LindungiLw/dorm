// JIUnity — data model for the foundation slice.
//
// NOTE ON THE DATASTORE: PostgreSQL. Serverless hosts (Vercel) have an ephemeral,
// read-only filesystem, so SQLite files can't persist there — a hosted Postgres
// (Neon / Vercel Postgres / Supabase) is required. Set DATABASE_URL to that connection
// string both locally (.env) and on Vercel (Environment Variables). For serverless,
// use the POOLED connection string at runtime; if `prisma db push` complains, use the
// DIRECT (non-pooled) string for that one command.
//
// Correctness invariants that MUST live in the datastore (per the architecture plan)
// are expressed as @@unique constraints below — e.g. one active coupon per (member,
// meal window) and exactly-once redemption via a unique ledger row.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// The generalized directory-synced principal. In production, identity fields
// (fullName, campusId, email, memberType, status, dormId) are a READ-ONLY projection
// synced from the campus SIS/directory; `allergyInfo` is JIUnity-owned. Here they are
// seeded locally. `passwordHash` stands in for the SSO credential until Google SSO is wired.
model Member {
  id           String   @id @default(cuid())
  memberType   String // STUDENT | FACULTY
  fullName     String
  campusId     String   @unique // NIM (students) or staff ID (faculty)
  email        String   @unique
  status       String   @default("ACTIVE") // ACTIVE | SUSPENDED | INACTIVE
  allergyInfo  String? // JIUnity-owned, sensitive
  photoUrl     String? // profile photo, stored as a small data URL (JIUnity-owned)
  dormId       String? // org-unit scope for dorm-scoped features
  // Last time the member was marked back at the dorm. The full ExitRequest is deleted on
  // return to keep that table lean, so this stamp is what powers the student's
  // "Back at campus" view.
  lastReturnAt DateTime?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roleAssignments RoleAssignment[]
  sessions        Session[]
  coupons         MealCoupon[]
  exitRequests    ExitRequest[]

  @@index([dormId])
}

// Many-to-many role assignments (a person may hold several roles), each optionally
// scoped to an org unit (dorm / cafeteria outlet). Buyer/seller are NOT roles.
model RoleAssignment {
  id        String  @id @default(cuid())
  memberId  String
  role      String // STUDENT | FACULTY | CAFETERIA_ADMIN | DORMITORY_ADMIN | ACADEMIC_ADMIN
  scopeType String? // DORM | OUTLET | null (campus-wide)
  scopeId   String?
  member    Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, role, scopeId])
  @@index([memberId])
}

// Stateful, revocable sessions. The cookie holds an opaque token; only its hash is
// stored. Revocation (suspend / role change / logout) sets revokedAt so it stops
// working on the next request — the property long-lived stateless JWTs can't give us.
model Session {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  memberId  String
  member    Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  @@index([memberId])
}

// A cafeteria counter/outlet. `secret` seeds the rotating presence-anchor code
// (a TOTP-style code that changes every 30s and is displayed AT the counter), so a
// screenshot is stale within seconds and redemption proves physical presence.
model Counter {
  id     String @id @default(cuid())
  name   String
  outlet String
  secret String
}

// A meal entitlement for one (member, date, meal window). The @@unique enforces
// "at most one coupon per member per meal window" — a datastore-level invariant.
model MealCoupon {
  id          String    @id @default(cuid())
  memberId    String
  member      Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  mealDate    String // YYYY-MM-DD (server-authoritative)
  mealType    String // BREAKFAST | LUNCH | DINNER
  status      String    @default("ISSUED") // ISSUED | ACTIVE | REDEEMED | EXPIRED
  activatedAt DateTime?
  redeemedAt  DateTime?
  redemption  Redemption?

  @@unique([memberId, mealDate, mealType])
  @@index([memberId, mealDate])
}

// Append-only redemption ledger. The @@unique on couponId is the exactly-once guard:
// two concurrent scans can't both insert, so a coupon is redeemed at most once.
model Redemption {
  id         String     @id @default(cuid())
  couponId   String     @unique
  coupon     MealCoupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  memberId   String
  counterId  String
  counterName String
  redeemedAt DateTime   @default(now())
}

// Exit-dorm permission request — the "reference workflow": student submits, a
// dorm-scoped admin approves/rejects via a guarded one-way state transition.
model ExitRequest {
  id          String    @id @default(cuid())
  memberId    String
  member      Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  dormId      String
  destination String
  departureAt DateTime
  returnAt    DateTime // expected return
  // Departure location point (captured when leaving the dorm).
  departureLat Float?
  departureLng Float?
  // Return pass: actual return time + location point (captured when back at the dorm).
  actualReturnAt DateTime?
  returnLat      Float?
  returnLng      Float?
  status      String    @default("OUT") // OUT | RETURNED (self-service, no approval)
  decidedById String?
  decidedAt   DateTime?
  decisionNote String?
  createdAt   DateTime  @default(now())

  @@index([dormId, status])
  @@index([memberId])
}

// The cafeteria menu for a given (date, meal window). Owned/edited by cafeteria staff;
// read by everyone. One row per (date, meal) via the @@unique.
model CafeteriaMenu {
  id          String   @id @default(cuid())
  menuDate    String // YYYY-MM-DD (server-authoritative)
  mealType    String // LUNCH | DINNER
  items       String // the dish / food served
  ingredients String? // ingredients that go into the dish
  updatedAt   DateTime @updatedAt

  @@unique([menuDate, mealType])
  @@index([menuDate])
}

// Admin-configurable meal check-in windows, in campus-local minutes since midnight.
// A missing row falls back to the code defaults (MEAL_WINDOWS in src/lib/time.ts).
model MealWindow {
  mealType  String   @id // LUNCH | DINNER
  startMin  Int
  endMin    Int
  updatedAt DateTime @updatedAt
}

// The cafeteria's food-allergen list: each dish and the allergens it contains. Maintained
// by cafeteria staff, read by everyone so members know what to avoid. Distinct from
// Member.allergyInfo (a member's OWN allergies).
model AllergenEntry {
  id        String   @id @default(cuid())
  food      String // dish / food name
  allergens String // allergens it contains, e.g. "Peanuts, Shellfish, Egg"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A borrowable item or bookable room, maintained by the permission (dorm) admin and read
// by everyone. `imageUrl` is a small data URL photo (falls back to `emoji`); `quantity` is
// how many are available (people for a room, units for equipment); `parts` is a JSON list
// of the components inside a set, e.g. a badminton set's rackets and shuttlecocks.
model BorrowItem {
  id          String   @id @default(cuid())
  name        String
  category    String   @default("OTHER") // ROOM | ELECTRONICS | LAB | SPORTS | MUSIC | OTHER
  imageUrl    String? // data URL of the item photo
  emoji       String? // icon fallback when there is no photo
  location    String   @default("")
  schedule    String   @default("")
  quantity    Int      @default(1) // how many available (capacity for a room, units otherwise)
  unitLabel   String   @default("units") // "people" for rooms/labs, "units" for equipment
  description String   @default("")
  parts       String? // JSON: [{ name, qty }] — the parts inside a set
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

// A marketplace product listing. Facilitator-only: `price` is a label in whole Rupiah;
// settlement is offline. Category is one of ELECTRONICS | FASHION | STATIONERY | FOOD_BEVERAGE.
model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Int // whole Rupiah (integer money, per the plan)
  category    String
  emoji       String? // placeholder visual until photo storage exists
  sellerId    String? // owner (member) — optional for seeded demo items
  createdAt   DateTime @default(now())

  @@index([category])
}

// A member's request/approval to become a marketplace seller, plus the QRIS payment
// details buyers use to pay them (facilitator-only: settlement is direct, off-platform).
model SellerProfile {
  id          String    @id @default(cuid())
  memberId    String    @unique
  storeName   String
  phone       String // WhatsApp / contact
  qrisNumber  String? // optional QRIS / merchant id
  qrisImage   String? // data URL of the seller's QRIS QR code
  status      String    @default("PENDING") // PENDING | APPROVED | REJECTED
  note        String? // admin decision note
  decidedById String?
  decidedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
}

// Append-only audit trail for privileged / value-affecting actions.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorName  String
  action     String
  targetType String
  targetId   String
  meta       String? // JSON string
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
}
