# JIUnity — environment variables (SAFE TEMPLATE, no real secrets).
# Copy to .env for local dev and fill in real values. NEVER commit the real .env.
# On Vercel, set these in Project → Settings → Environment Variables (not in git).

# --- Database ---
# Local dev uses SQLite:
#   DATABASE_URL="file:./dev.db"
# Vercel is serverless — SQLite files do NOT persist there. Use a hosted Postgres
# (Vercel Postgres / Neon / Supabase) and switch prisma/schema.prisma provider to
# "postgresql". Example:
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# --- Auth.js / NextAuth v5 ---
# Generate a strong secret with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="generate-a-long-random-string"
AUTH_TRUST_HOST="true"

# --- Google OAuth (campus @jiu.ac SSO) ---
# From Google Cloud Console → Credentials → OAuth 2.0 Client ID.
# Add your production redirect URI:
#   https://YOUR-APP.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
